# Copy this file to `.env` for local development. Never commit real secrets.
# On Hugging Face Spaces, set the same variable names under
# Settings -> Variables and secrets.

# Full JSON of a Google Cloud service account key (one line of valid JSON).
# Paste the entire contents of the key file you downloaded from
# IAM & Admin -> Service Accounts -> Keys. The service account must have
# roles/serviceusage.serviceUsageConsumer and roles/earthengine.writer on a
# GCP project that is registered for Earth Engine. See README.md.
# GCP_SERVICE_ACCOUNT_JSON=

# GCP project id (the lowercase string from the Cloud Console, not the
# display name or numeric project number). Optional: if omitted, the project
# id is read from `project_id` inside GCP_SERVICE_ACCOUNT_JSON.
# EE_PROJECT_ID=
